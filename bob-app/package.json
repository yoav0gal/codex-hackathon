{
  "name": "codex-hackathon-realtime-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/application/main/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "start": "npm run build && electron .",
    "setup:wake": "node scripts/install-wake-model.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "codex:prepare": "./scripts/codex-shared-daemon.sh prepare",
    "codex:launch": "./scripts/codex-shared-daemon.sh launch",
    "codex:status": "./scripts/codex-shared-daemon.sh status"
  },
  "dependencies": {
    "dotenv": "^17.2.0",
    "sherpa-onnx": "^1.13.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.0",
    "electron": "^43.1.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.7",
    "wait-on": "^8.0.3"
  }
}
